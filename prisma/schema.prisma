// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

enum Rol {
  ADMIN
  COBRADOR
}

enum TipoInteres {
  FRANCES
  ALEMAN
  SIMPLE
}

enum Frecuencia {
  DIARIA
  SEMANAL
  QUINCENAL
  MENSUAL
}

enum EstadoPrestamo {
  ACTIVO
  PAGADO
  ATRASADO
  CANCELADO
  REFINANCIADO
}

enum EstadoCuota {
  PENDIENTE
  PARCIAL
  PAGADA
  ATRASADA
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  OTRO
}

model Empresa {
  id        String   @id @default(cuid())
  nombre    String
  ruc       String?
  telefono  String?
  direccion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  usuarios         Usuario[]
  clientes         Cliente[]
  prestamos        Prestamo[]
  pagos            Pago[]
  simulaciones     Simulacion[]
  refinanciaciones Refinanciacion[]
  auditorias       Auditoria[]
}

model Usuario {
  id        String   @id @default(cuid())
  empresaId String
  nombre    String
  email     String   @unique
  password  String
  rol       Rol      @default(COBRADOR)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id])

  clientes         Cliente[]
  prestamos        Prestamo[]
  pagos            Pago[]
  simulaciones     Simulacion[]
  refinanciaciones Refinanciacion[]
  auditorias       Auditoria[]

  @@index([empresaId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Cliente {
  id        String   @id @default(cuid())
  empresaId String
  nombre    String
  apellido  String
  documento String
  telefono  String
  direccion String?
  email     String?
  usuarioId String
  createdAt DateTime @default(now())

  empresa   Empresa    @relation(fields: [empresaId], references: [id])
  usuario   Usuario    @relation(fields: [usuarioId], references: [id])
  prestamos Prestamo[]

  @@unique([empresaId, documento])
  @@index([usuarioId])
  @@index([empresaId])
}

model Prestamo {
  id             String         @id @default(cuid())
  empresaId      String
  clienteId      String
  usuarioId      String
  monto          Decimal        @db.Decimal(12, 2)
  tasaInteres    Decimal        @db.Decimal(6, 3)
  iva            Decimal        @default(0) @db.Decimal(5, 2)
  cantidadCuotas Int
  tipoInteres    TipoInteres
  frecuencia     Frecuencia
  fechaInicio    DateTime
  estado         EstadoPrestamo @default(ACTIVO)
  createdAt      DateTime       @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  cuotas  Cuota[]
  pagos   Pago[]

  refinanciacionComoAnterior Refinanciacion? @relation("RefinanciacionAnterior")
  refinanciacionComoNuevo    Refinanciacion? @relation("RefinanciacionNuevo")

  @@index([clienteId])
  @@index([usuarioId])
  @@index([empresaId])
}

model Cuota {
  id               String      @id @default(cuid())
  prestamoId       String
  numero           Int
  fechaVencimiento DateTime
  montoCapital     Decimal     @db.Decimal(12, 2)
  montoInteres     Decimal     @db.Decimal(12, 2)
  montoTotal       Decimal     @db.Decimal(12, 2)
  montoPagado      Decimal     @default(0) @db.Decimal(12, 2)
  estado           EstadoCuota @default(PENDIENTE)
  createdAt        DateTime    @default(now())

  prestamo Prestamo @relation(fields: [prestamoId], references: [id])
  pagos    Pago[]

  @@index([prestamoId])
}

model Pago {
  id             String     @id @default(cuid())
  empresaId      String
  cuotaId        String
  prestamoId     String
  usuarioId      String
  monto          Decimal    @db.Decimal(12, 2)
  fechaPago      DateTime   @default(now())
  metodoPago     MetodoPago @default(EFECTIVO)
  observacion    String?
  idempotencyKey String?
  createdAt      DateTime   @default(now())

  empresa  Empresa  @relation(fields: [empresaId], references: [id])
  cuota    Cuota    @relation(fields: [cuotaId], references: [id])
  prestamo Prestamo @relation(fields: [prestamoId], references: [id])
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([empresaId, idempotencyKey])
  @@index([cuotaId])
  @@index([prestamoId])
  @@index([usuarioId])
  @@index([empresaId])
}

model Simulacion {
  id             String      @id @default(cuid())
  empresaId      String
  usuarioId      String
  clienteNombre  String
  clienteEmail   String?
  monto          Decimal     @db.Decimal(12, 2)
  tasaInteres    Decimal     @db.Decimal(6, 3)
  iva            Decimal     @default(0) @db.Decimal(5, 2)
  cantidadCuotas Int
  tipoInteres    TipoInteres
  frecuencia     Frecuencia
  fechaInicio    DateTime
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([empresaId])
}

model Refinanciacion {
  id                 String   @id @default(cuid())
  empresaId          String
  prestamoAnteriorId String   @unique
  prestamoNuevoId    String   @unique
  usuarioId          String
  saldoAnterior      Decimal  @db.Decimal(12, 2)
  montoAdicional     Decimal  @default(0) @db.Decimal(12, 2)
  observacion        String?
  createdAt          DateTime @default(now())

  empresa          Empresa  @relation(fields: [empresaId], references: [id])
  prestamoAnterior Prestamo @relation("RefinanciacionAnterior", fields: [prestamoAnteriorId], references: [id])
  prestamoNuevo    Prestamo @relation("RefinanciacionNuevo", fields: [prestamoNuevoId], references: [id])
  usuario          Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([empresaId])
}

model Auditoria {
  id         String   @id @default(cuid())
  empresaId  String
  tabla      String
  accion     String
  registroId String
  oldValues  String?
  newValues  String?
  usuarioId  String
  createdAt  DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([tabla])
  @@index([usuarioId])
  @@index([empresaId])
}
